# Backends:
# - ollama: local Ollama server
# - openai_compat: LM Studio or other OpenAI-compatible local server
# - hermes: Nous Hermes Agent (OpenAI-compatible API via hermes gateway)
# - unsloth: Unsloth FastLanguageModel (train + infer) — https://github.com/unslothai/unsloth
# - huggingface: direct local Transformers inference
#
# Recommended Ollama models (pull with: ollama pull <name>)
# llama3       - General security methodology
# llama3.1     - Better instructions
# mistral      - Fast default
# codellama    - Code/exploit scripting
# deepseek-coder:6.7b - CTF scripting

MODEL_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
OPENAI_COMPAT_MODEL=local-model
OPENAI_COMPAT_API_KEY=lm-studio

# AI Router — intent lanes (code/compliance/intel/report) + optional cloud providers
# Docs: docs/ai-router.md — without keys, router still classifies and stays on local backend
ROUTER_ENABLED=true
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# TOGETHER_API_KEY=
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# FIREWORKS_API_KEY=
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
# Optional Ollama coder override for code-lane when MODEL_BACKEND=ollama
# OLLAMA_CODER_MODEL=qwen2.5-coder:7b
# Lane model overrides (used when corresponding cloud key is set)
# ROUTER_CODE_MODEL=qwen/qwen2.5-coder-32b-instruct
# ROUTER_COMPLIANCE_MODEL=gpt-4o-mini
# ROUTER_REPORT_MODEL=gpt-4o-mini
# ROUTER_INTEL_MODEL=llama-3.3-70b-versatile
# ROUTER_CLOUD_MODEL=openai/gpt-4o-mini

# Hermes Agent — https://github.com/NousResearch/hermes-agent
# Enable API server in Hermes: API_SERVER_ENABLED=true + matching API_SERVER_KEY
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=hermes-agent
HERMES_API_KEY=change-me-local-dev
# Stable memory scope (X-Hermes-Session-Key)
HERMES_SESSION_KEY=securaiq-pentest
HERMES_SHOW_TOOL_PROGRESS=true

# Hugging Face token (gated models / Unsloth downloads). Also editable in UI Settings.
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Unsloth — https://github.com/unslothai/unsloth
UNSLOTH_MODEL=unsloth/Qwen2.5-0.5B-Instruct-bnb-4bit
UNSLOTH_ADAPTER_DIR=./models/securaiq-unsloth
UNSLOTH_MAX_SEQ_LENGTH=2048
UNSLOTH_LOAD_IN_4BIT=true

# Live web search (faster parallel search; detailed CVE/page context)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=8
WEB_SEARCH_TIMEOUT_SEC=5
# Optional self-hosted SearXNG (preferred when set)
# SEARXNG_URL=http://127.0.0.1:8088

# Network vuln assess (lab/private IPs; public only with UI authorize checkbox)
NET_ASSESS_ENABLED=true
NET_ASSESS_USE_NMAP=true

# Local security tools (builtins always; nmap/nikto/nuclei/… when on PATH)
LOCAL_TOOLS_ENABLED=true
LOCAL_TOOLS_AUTO=true
# Heavy scanners (nuclei/nikto/ffuf/gobuster) only when user instructs, unless true:
LOCAL_TOOLS_ALLOW_HEAVY=false

# Bind 127.0.0.1 for hardened local; use 0.0.0.0 only behind a firewall / Docker
HOST=127.0.0.1
PORT=8080
DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
# false = empty/fast start (index knowledge via UI Re-index). true = ingest data/knowledge on boot
RAG_AUTO_INGEST=false
# Optional Qdrant (docker compose --profile vectors up)
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_COLLECTION=securaiq_knowledge
UPLOAD_MAX_MB=15

# Auth / commercial (off by default for easy local labs)
AUTH_ENABLED=false
AUTH_ALLOW_REGISTER=true
BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-me

# Jira (optional — create issues from remediations)
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=SEC
