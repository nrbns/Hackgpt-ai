# Backends:
# - ollama: local Ollama server
# - openai_compat: LM Studio or other OpenAI-compatible local server
# - huggingface: direct local Transformers inference
#
# Recommended Ollama models (pull with: ollama pull <name>)
# llama3       - General security methodology
# llama3.1     - Better instructions
# mistral      - Fast default
# codellama    - Code/exploit scripting
# deepseek-coder:6.7b - CTF scripting

MODEL_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
OPENAI_COMPAT_MODEL=local-model
OPENAI_COMPAT_API_KEY=lm-studio

HF_MODEL=microsoft/Phi-3-mini-4k-instruct
HOST=0.0.0.0
PORT=8080
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
